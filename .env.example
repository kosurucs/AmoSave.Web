# AmoSave Web — Environment Variables
#
# Copy this file to .env.local (never commit .env.local) and fill in the values.
# For CI/CD (GitHub Actions + Azure), add these as GitHub repository secrets.
#
# ─────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the AmoSave .NET API
# Example: https://amosave-api.azurewebsites.net/api/v1
VITE_API_BASE_URL=http://localhost:5208/api/v1

# API key used by the interceptor (x-api-key header)
VITE_API_KEY=your_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Azure CI/CD secret (set in GitHub → Settings → Secrets → Actions)
# ─────────────────────────────────────────────────────────────────────────────

# Deployment token from your Azure Static Web App resource
# Azure Portal → Static Web App → Manage deployment token
AZURE_STATIC_WEB_APPS_API_TOKEN=<paste token here — do NOT commit>
